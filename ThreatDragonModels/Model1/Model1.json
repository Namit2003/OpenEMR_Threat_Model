          "z": 0,
          "attrs": {},
          "data": {
            "name": "TB-1: Internet Boundary",
            "description": "Untrusted external users (patients, staff) connecting to OpenEMR over the public internet"
          },
          "label": "TB-1: Internet Boundary"
        },
        {
          "type": "tm.BoundaryBox",
          "size": { "width": 1180, "height": 1150 },
          "position": { "x": 290, "y": 10 },
          "angle": 0,
          "id": "tb-2",
          "z": 0,
          "attrs": {},
          "data": {
            "name": "TB-2: OpenEMR Application Layer",
            "description": "Application processes and database stores running inside the server environment. PHP application tier and MySQL database tier."
          },
          "label": "TB-2: OpenEMR Application Layer"
        },
        {
          "type": "tm.BoundaryBox",
          "size": { "width": 280, "height": 900 },
          "position": { "x": 1490, "y": 10 },
          "angle": 0,
          "id": "tb-3",
          "z": 0,
          "attrs": {},
          "data": {
            "name": "TB-3: External Services Boundary",
            "description": "Third-party external services: laboratories, pharmacies, insurance companies, payment processors, and external health systems"
          },
          "label": "TB-3: External Services"
        },
        {
          "type": "tm.BoundaryBox",
          "size": { "width": 260, "height": 210 },
          "position": { "x": 1000, "y": 510 },
          "angle": 0,
          "id": "tb-4",
          "z": 1,
          "attrs": {},
          "data": {
            "name": "TB-4: Patient Portal Sub-Boundary",
            "description": "Separate trust zone for the patient-facing portal with its own session management and reduced privilege set compared to staff interfaces"
          },
          "label": "TB-4: Patient Portal"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 40, "y": 80 },
          "angle": 0,
          "id": "ee-1",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Patient",
            "description": "End user accessing the patient portal. Submits demographics, views lab results and billing, sends secure messages, makes payments, and submits questionnaires.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Patient"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 40, "y": 560 },
          "angle": 0,
          "id": "ee-2",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Provider / Staff",
            "description": "Clinicians and administrative staff using the full OpenEMR web UI. Documents clinical encounters, manages orders and prescriptions, handles billing and scheduling.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Provider / Staff"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 1510, "y": 80 },
          "angle": 0,
          "id": "ee-3",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Laboratory",
            "description": "External laboratory system (e.g., LabCorp, Quest). Receives HL7 ORM lab orders from OpenEMR and returns HL7 ORU result messages.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Laboratory"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 1510, "y": 230 },
          "angle": 0,
          "id": "ee-4",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Pharmacy",
            "description": "External pharmacy system. Receives electronic prescriptions (eRx via SOAP/XML). Returns prescription status and formulary/insurance data via WENO module.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Pharmacy"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 1510, "y": 380 },
          "angle": 0,
          "id": "ee-5",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Insurance Company",
            "description": "Health insurance payer. Receives EDI X12 837 claims and eligibility requests (270). Returns ERA/EOB responses and eligibility results (271).",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Insurance Company"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 1510, "y": 530 },
          "angle": 0,
          "id": "ee-6",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "Payment Processor",
            "description": "Third-party payment gateway (Stripe, AuthorizeNet, RainForest). Processes credit card payments from patients via the portal or front desk.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "Payment Processor"
        },
        {
          "type": "tm.Actor",
          "size": { "width": 160, "height": 80 },
          "position": { "x": 1510, "y": 680 },
          "angle": 0,
          "id": "ee-7",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "External Health System",
            "description": "Other healthcare organizations. Exchanges FHIR R4 resources via the REST API, CCDA clinical documents, Direct secure messages, and QRDA quality reports with OpenEMR.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "External Health System"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 350, "y": 95 },
          "angle": 0,
          "id": "p1",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P1: Authentication & Access Control",
            "description": "Handles all login flows: username/password, MFA (TOTP), Google SSO, and OAuth2/SMART on FHIR for API clients. Validates credentials against hashed passwords in users_secure. Loads GACL role-based permissions. Issues session cookies or OAuth2 JWTs.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "High",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P1: Auth &\nAccess Control"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 350, "y": 415 },
          "angle": 0,
          "id": "p2",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P2: Patient Registration & Scheduling",
            "description": "Captures and manages patient demographics and insurance information. Handles appointment scheduling via the calendar, patient check-in, and patient flow tracking (patient_tracker). Supports patient self-registration via the portal.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "Medium",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P2: Registration\n& Scheduling"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 820, "y": 415 },
          "angle": 0,
          "id": "p3",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P3: Clinical Encounter & Order Management",
            "description": "Core clinical workflow: creates encounters, records SOAP notes, vitals, diagnoses, and problem lists. Sends HL7 ORM lab orders to labs. Receives and parses HL7 ORU results. Sends electronic prescriptions (eRx). Exports CCDA documents and FHIR R4 resources.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "High",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P3: Clinical\nEncounter & Orders"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 350, "y": 735 },
          "angle": 0,
          "id": "p4",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P4: Billing & Claims Processing",
            "description": "Converts encounter data into billing entries. Generates and submits EDI X12 837 claims to insurers. Receives and reconciles ERA/EOB responses. Processes patient payments through payment gateways. Manages accounts receivable and patient balances.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "High",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P4: Billing &\nClaims Processing"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 1040, "y": 555 },
          "angle": 0,
          "id": "p5",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P5: Patient Portal & Communication",
            "description": "Patient-facing portal for secure messaging, document access, lab result viewing, appointment requests, questionnaire submission, and online bill payment. Also handles internal provider-to-patient communications and document publishing.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "Low",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P5: Patient Portal\n& Communication"
        },
        {
          "type": "tm.Process",
          "size": { "width": 140, "height": 70 },
          "position": { "x": 670, "y": 935 },
          "angle": 0,
          "id": "p6",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "P6: Reporting, Audit & Quality Measures",
            "description": "Generates clinical, financial, and operational reports. Computes Clinical Quality Measures (CQM) and exports QRDA XML for CMS submission. Provides HIPAA-compliant audit trail. Supports chart access tracking.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "Medium",
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "P6: Reporting,\nAudit & QM"
        },
        {
