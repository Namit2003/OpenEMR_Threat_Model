            "reasonOutOfScope": "",
            "isALog": false,
            "storesCredentials": false,
            "isEncrypted": false,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-2: Patient\nRecord Store"
