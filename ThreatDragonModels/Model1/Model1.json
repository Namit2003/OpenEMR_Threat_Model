            "reasonOutOfScope": "",
            "isALog": false,
            "storesCredentials": true,
            "isEncrypted": true,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-1: User &\nSession Store"
