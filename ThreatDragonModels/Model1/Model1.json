            "reasonOutOfScope": "",
            "isALog": false,
            "storesCredentials": false,
            "isEncrypted": false,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-4: Billing &\nInsurance Store"
