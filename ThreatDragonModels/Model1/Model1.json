          "angle": 0,
          "id": "ds-2",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-2: Patient Record Store",
            "description": "Tables: patient_data, patient_history, form_encounter, openemr_postcalendar_events, patient_tracker. Stores patient demographics, medical history, encounter metadata, appointments, and check-in status.",
