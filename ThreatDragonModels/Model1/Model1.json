          "angle": 0,
          "id": "ds-1",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-1: User & Session Store",
            "description": "Tables: users, users_secure, session_tracker, gacl_*, login_mfa_registrations, api_token, oauth_clients. Stores hashed credentials, active sessions, role-based access rules, MFA registrations, and OAuth2 tokens.",
