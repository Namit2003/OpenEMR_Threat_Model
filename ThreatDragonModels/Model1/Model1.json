        {
          "type": "tm.Store",
          "size": { "width": 180, "height": 60 },
          "position": { "x": 1010, "y": 415 },
          "angle": 0,
          "id": "ds-3",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-3: Clinical Data Store",
            "description": "Tables: lists, immunizations, prescriptions, procedure_order, procedure_report, procedure_result, form_soap, form_vitals. Stores diagnoses, medications, lab orders and results, SOAP notes, vitals.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "isALog": false,
            "storesCredentials": false,
            "isEncrypted": false,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-3: Clinical\nData Store"
        },
        {
          "type": "tm.Store",
          "size": { "width": 180, "height": 60 },
          "position": { "x": 600, "y": 735 },
          "angle": 0,
          "id": "ds-4",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-4: Billing & Insurance Store",
            "description": "Tables: billing, claims, payments, insurance_data, ar_session, ar_activity, fee_schedule. Stores billing entries, submitted claims, insurance details, payment records, and accounts receivable.",
