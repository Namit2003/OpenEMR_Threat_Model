        {
          "type": "tm.Store",
          "size": { "width": 180, "height": 60 },
          "position": { "x": 670, "y": 1060 },
          "angle": 0,
          "id": "ds-5",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-5: Audit & Log Store",
            "description": "Tables: audit_master, audit_details, log, extended_log, api_log, chart_tracker. Stores all system audit events for HIPAA compliance and forensic review. Tamper-resistant record of all user and API actions.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "isALog": true,
            "storesCredentials": false,
            "isEncrypted": false,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-5: Audit &\nLog Store"
        },
        {
          "type": "tm.Store",
          "size": { "width": 180, "height": 60 },
          "position": { "x": 1010, "y": 675 },
          "angle": 0,
          "id": "ds-6",
          "z": 2,
          "attrs": {},
          "data": {
            "name": "DS-6: Messaging & Document Store",
            "description": "Tables: onsite_messages, onsite_mail, documents, pnotes, direct_message_log, email_queue. Stores patient portal messages, internal staff messages, uploaded documents, patient notes, and outbound email queue.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "isALog": false,
            "storesCredentials": false,
            "isEncrypted": false,
            "isSigned": false,
            "hasOpenThreats": false,
            "threats": []
          },
          "label": "DS-6: Messaging &\nDocument Store"
